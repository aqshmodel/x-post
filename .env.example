# ==================================
# X投稿システム 環境変数テンプレート
# ==================================
# このファイルをコピーして .env を作成してください
# cp .env.example .env

# ----------------------------------
# X Developer App（共通）
# ----------------------------------
X_APP_API_KEY=
X_APP_API_SECRET=

# ----------------------------------
# アカウント別 OAuth トークン
# 命名規則: X_{ACCOUNT_NAME(大文字)}_{KEY}
# ----------------------------------

# アカウント例: ACCOUNT_A
X_ACCOUNT_A_ACCESS_TOKEN=
X_ACCOUNT_A_ACCESS_TOKEN_SECRET=
X_ACCOUNT_A_BEARER_TOKEN=

# アカウント例: ACCOUNT_B
# X_ACCOUNT_B_ACCESS_TOKEN=
# X_ACCOUNT_B_ACCESS_TOKEN_SECRET=
# X_ACCOUNT_B_BEARER_TOKEN=
